<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ACS_NexTrip.Pages.HomePage"
             Shell.NavBarIsVisible="False"
             Title="HomePage">

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Header personnalisé -->
        <Border Grid.Row="0" 
            BackgroundColor="White"
            Padding="20,10">
            <Border.Shadow>
                <Shadow Brush="{StaticResource Gray900}"
                    Offset="0,2"
                    Radius="8"
                    Opacity="0.1"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto, *, Auto" 
              ColumnSpacing="20"
              HeightRequest="60">

                <!-- Logo à gauche -->
                <HorizontalStackLayout Grid.Column="0" 
                                   Spacing="10" 
                                   VerticalOptions="Center">
                    <Border BackgroundColor="{StaticResource Orange500}"
                        HeightRequest="40"
                        WidthRequest="40"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="TM" 
                           FontSize="18" 
                           FontAttributes="Bold" 
                           TextColor="Orange"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    </Border>
                    <Label Text="TravelManager" 
                       FontSize="22" 
                       FontAttributes="Bold" 
                       TextColor="Orange"
                       VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Boutons de navigation au centre -->
                <HorizontalStackLayout Grid.Column="1" 
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center"
                                   Spacing="30">

                    <!-- Accueil actif -->
                    <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                        <Label Text="Accueil" 
                        TextColor="Orange" 
                        FontSize="14"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"/>
                        <BoxView HeightRequest="2" Color="{StaticResource Orange500}" HorizontalOptions="Fill"/>
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToDashboardCommand}"/>
                        </VerticalStackLayout.GestureRecognizers>
                    </VerticalStackLayout>

                    <!-- Trajets actif -->
                    <VerticalStackLayout VerticalOptions="Center" Spacing="5" Padding="10,0">
                        <Label Text="Trajets" 
                            TextColor="Orange" 
                            FontSize="14"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"/>

                        <BoxView HeightRequest="2" 
                                 Color="Transparent" 
                                 HorizontalOptions="Fill"/>

                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToTripsCommand}"/>
                        </VerticalStackLayout.GestureRecognizers>
                    </VerticalStackLayout>

                    <!-- Utilisateurs actif -->
                    <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                        <Label Text="Paramètre" 
                        TextColor="Orange" 
                        FontSize="14"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"/>
                        <BoxView HeightRequest="2" Color="Transparent" HorizontalOptions="Fill"/>
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToUsersCommand}"/>
                        </VerticalStackLayout.GestureRecognizers>
                    </VerticalStackLayout>

                </HorizontalStackLayout>

                <!-- Profil utilisateur à droite -->
                <HorizontalStackLayout Grid.Column="2" 
                                   Spacing="15" 
                                   VerticalOptions="Center">

                    <!-- Notifications -->
                    <Border BackgroundColor="White"
                        HeightRequest="40"
                        WidthRequest="40"
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Label Text="🔔" 
                           FontSize="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowNotificationsCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Profil utilisateur -->
                    <Border BackgroundColor="Orange"
                        HeightRequest="45"
                        WidthRequest="45"
                        StrokeThickness="2"
                        Stroke="{StaticResource Orange300}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22.5"/>
                        </Border.StrokeShape>
                        <Label Text="JD" 
                           FontSize="16" 
                           FontAttributes="Bold" 
                           TextColor="Black"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowProfileCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>

                    <!-- Nom utilisateur -->
                    <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                        <Label Text="Jean Dupont" 
                           FontSize="14" 
                           FontAttributes="Bold"
                           TextColor="Black"/>
                        <Label Text="Administrateur" 
                           FontSize="11"
                           TextColor="Black"/>
                    </VerticalStackLayout>

                </HorizontalStackLayout>

            </Grid>
        </Border>

        <!-- Contenu principal -->
        <ScrollView Grid.Row="1" BackgroundColor="white">
            <VerticalStackLayout>

                <!-- Section avec le fond (jusqu'après les cartes) -->
                <Grid>
                    <Image Source="background_travel.jpg" Aspect="AspectFill" VerticalOptions="Fill" HorizontalOptions="Fill" />

                    <VerticalStackLayout Padding="30" Spacing="20">

                        <!-- Titre de la page -->
                        <Label Text="Où allez-vous ?" 
                           FontSize="32" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"/>

                        <Label Text="Planifiez votre prochain voyage en quelque clics"
                   FontSize="16"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"/>

                        <!-- Barre de recherche -->
                        <Border BackgroundColor="White"
                        Padding="30"
                        Margin="0, 10, 0, 10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="{StaticResource Gray900}" Offset="0,4" Radius="15" Opacity="0.1"/>
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="20">
                                <!-- Champs de recherche -->
                                <Grid ColumnDefinitions="*, *, *, *" ColumnSpacing="15" BackgroundColor="White">

                                    <!-- D'où partez-vous -->
                                    <Border Grid.Column="0" Stroke="{StaticResource Gray300}" StrokeThickness="1" BackgroundColor="Transparent" Padding="15,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                            <Label Text="📍" VerticalOptions="Center" TextColor="{StaticResource Gray500}"/>
                                            <Entry Placeholder="D'où partez-vous ?" BackgroundColor="Transparent" VerticalOptions="Center" HorizontalOptions="Fill"/>
                                        </HorizontalStackLayout>
                                    </Border>

                                    <!-- Où allez-vous -->
                                    <Border Grid.Column="1" Stroke="{StaticResource Gray300}" StrokeThickness="1" BackgroundColor="Transparent" Padding="15,0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                            <Label Text="📍" VerticalOptions="Center" TextColor="{StaticResource Orange500}"/>
                                            <Entry Placeholder="Où allez-vous ?" BackgroundColor="Transparent" VerticalOptions="Center" HorizontalOptions="Fill"/>
                                        </HorizontalStackLayout>
                                    </Border>

                                    <!-- Date -->
                                    <Border Grid.Column="2" Stroke="{StaticResource Gray300}" StrokeThickness="1" BackgroundColor="Transparent" Padding="15,0" HeightRequest="45">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                            <Label Text="📅" VerticalOptions="Center" TextColor="Black"/>
                                            <DatePicker BackgroundColor="Transparent" VerticalOptions="Center" HorizontalOptions="Fill" TextColor="Black"/>
                                        </HorizontalStackLayout>
                                    </Border>

                                    <!-- Heure -->
                                    <Border Grid.Column="3" Stroke="{StaticResource Gray300}" StrokeThickness="1" BackgroundColor="Transparent" Padding="15,0" HeightRequest="45">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="10"/>
                                        </Border.StrokeShape>
                                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                            <Label Text="🕒" VerticalOptions="Center" TextColor="Black"/>
                                            <TimePicker BackgroundColor="Transparent" VerticalOptions="Center" HorizontalOptions="Fill" TextColor="Black"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>

                                <!-- Bouton Rechercher -->
                                <Button Text="🔍 Rechercher" 
                                BackgroundColor="{StaticResource Orange500}"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="20"
                                HeightRequest="45"
                                WidthRequest="200"
                                HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Statistiques rapides -->
                        <Grid ColumnDefinitions=" *, *, *, *" ColumnSpacing="20">

                            <!-- Card 1 -->
                            <Border Grid.Column="0" 
                        BackgroundColor="White"
                        Padding="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource Gray900}"
                                Offset="0,4"
                                Radius="15"
                                Opacity="0.1"/>
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="🛣️ Voir mes trajets" FontSize="22" TextColor="Black"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Card 2 -->
                            <Border Grid.Column="1" 
                        BackgroundColor="White"
                        Padding="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource Gray900}"
                                Offset="0,4"
                                Radius="15"
                                Opacity="0.1"/>
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="📍 Réserver un nouveau trajet" FontSize="22" TextColor="Black"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Card 3 -->
                            <Border Grid.Column="2" 
                        BackgroundColor="White"
                        Padding="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource Gray900}"
                                Offset="0,4"
                                Radius="15"
                                Opacity="0.1"/>
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="⏱️ Historique" FontSize="22" TextColor="Black"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Card 4 -->
                            <Border Grid.Column="3" 
                        BackgroundColor="White"
                        Padding="50">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource Gray900}"
                                Offset="0,4"
                                Radius="15"
                                Opacity="0.1"/>
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="10">
                                    <Label Text="ℹ️ Infos trafic" FontSize="22" TextColor="Black"/>
                                </VerticalStackLayout>
                            </Border>

                        </Grid>

                    </VerticalStackLayout>
                </Grid>

                <!-- Section inférieure (sans le fond nuage) -->
                <VerticalStackLayout Padding="30, 20, 30, 30">

                    <!-- Section trajets récents -->
                    <VerticalStackLayout Spacing="15" Margin="0,0,0,20">
                        <Label Text="Prochains trajets" 
                           FontSize="24" 
                           FontAttributes="Bold"
                           TextColor="Black"/>
                    </VerticalStackLayout>


                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
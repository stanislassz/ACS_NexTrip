<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_NexTrip.ViewModel"
             xmlns:models="clr-namespace:ACS_NexTrip.Models"
             x:Class="ACS_NexTrip.Pages.TrajetPage"
             x:DataType="vm:TrajetViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark={StaticResource Gray900}}"
             Title="Trajets">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" BackgroundColor="White" Padding="20,10">
            <Border.Shadow>
                <Shadow Brush="{StaticResource Gray900}" Offset="0,2" Radius="8" Opacity="0.1"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="20" HeightRequest="60">

                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Border BackgroundColor="Orange" HeightRequest="40" WidthRequest="40" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="TM" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="TravelManager" FontSize="22" FontAttributes="Bold" TextColor="Orange" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="30">
                    <!-- Accueil actif -->
<VerticalStackLayout VerticalOptions="Center" Spacing="5">
    <Label Text="Accueil" 
       TextColor="Orange" 
       FontSize="14"
       FontAttributes="Bold"
       HorizontalOptions="Center"/>
    <BoxView HeightRequest="2" Color="Transparent" HorizontalOptions="Fill"/>
    <VerticalStackLayout.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding NavigateToDashboardCommand}"/>
    </VerticalStackLayout.GestureRecognizers>
</VerticalStackLayout>

<!-- Trajets actif -->
<VerticalStackLayout VerticalOptions="Center" Spacing="5" Padding="10,0">
    <Label Text="Trajets" 
           TextColor="Orange" 
           FontSize="14"
           FontAttributes="Bold"
           HorizontalOptions="Center"/>

                        <BoxView HeightRequest="2" 
             Color="Orange" 
             HorizontalOptions="Fill"/>

    <VerticalStackLayout.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding NavigateToTripsCommand}"/>
    </VerticalStackLayout.GestureRecognizers>
</VerticalStackLayout>

<!-- Paramètre inactif -->
<VerticalStackLayout VerticalOptions="Center" Spacing="5">
    <Label Text="Paramètre" 
       TextColor="Orange" 
       FontSize="14"
       FontAttributes="Bold"
       HorizontalOptions="Center"/>
    <BoxView HeightRequest="2" Color="Transparent" HorizontalOptions="Fill"/>
    <VerticalStackLayout.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding NavigateToUsersCommand}"/>
    </VerticalStackLayout.GestureRecognizers>
</VerticalStackLayout>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="2" Spacing="15" VerticalOptions="Center">
                    <Label Text="🔔" FontSize="20" VerticalOptions="Center"/>
                    <Border BackgroundColor="Orange" HeightRequest="45" WidthRequest="45" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22.5"/>
                        </Border.StrokeShape>
                        <Label Text="JD" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Padding="30">
            <CollectionView ItemsSource="{Binding Trajets}">

                <CollectionView.Header>
                    <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                        <VerticalStackLayout Grid.Column="0" Spacing="5">
                            <Label Text="Trajets Disponibles" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Gray900}"/>
                            <Label Text="Consultez les voyages et réservations en cours" FontSize="14" TextColor="{StaticResource Gray600}"/>
                        </VerticalStackLayout>

                        <Button Grid.Column="1"
                                Text="+"
                                FontSize="24"
                                FontAttributes="Bold"
                                TextColor="White"
                                BackgroundColor="Orange"
                                HeightRequest="50"
                                WidthRequest="50"
                                CornerRadius="25"
                                VerticalOptions="Center"
                                Command="{Binding GoToAddTrajetCommand}"/>
                    </Grid>
                </CollectionView.Header>

                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Trajet">
                        <Border BackgroundColor="White" Padding="20">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.05"/>
                            </Border.Shadow>

                            <Grid ColumnDefinitions="Auto, *, Auto, Auto" ColumnSpacing="20">

                                <Border Grid.Column="0" BackgroundColor="#E3F2FD" HeightRequest="60" WidthRequest="60" StrokeThickness="0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="30"/>
                                    </Border.StrokeShape>
                                    <Label Text="✈️" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>

                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="{Binding TRA_LIEU_DEPART}" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                                        <Label Text="➔" FontSize="18" TextColor="Orange" VerticalOptions="Center"/>
                                        <Label Text="{Binding TRA_LIEU_ARRIVEE}" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="15">
                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="📅" FontSize="12"/>
                                            <Label Text="{Binding AffichageDepart}" TextColor="{StaticResource Gray600}" FontSize="13"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="🏷️" FontSize="12"/>
                                            <Label Text="{Binding TYP_LIBELLE}" TextColor="{StaticResource Gray600}" FontSize="13"/>
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                                    <Label Text="{Binding TRA_PRIX, StringFormat='{0:F2} €'}" 
                                           FontSize="20" 
                                           FontAttributes="Bold" 
                                           TextColor="Orange"/>
                                    <Border BackgroundColor="#FFF3E0" Padding="8,2">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="5"/>
                                        </Border.StrokeShape>
                                        <Label Text="Disponible" FontSize="10" TextColor="Orange" FontAttributes="Bold"/>
                                    </Border>
                                </VerticalStackLayout>

                                <Button Grid.Column="3"
                                        Text="🗑️"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TrajetViewModel}}, Path=DeleteTrajetCommand}"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="Transparent" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
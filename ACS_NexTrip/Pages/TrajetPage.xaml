<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="using:ACS_NexTrip.ViewModel"
             xmlns:models="using:ACS_NexTrip.Models"
             x:Class="ACS_NexTrip.Pages.TrajetPage"
             x:DataType="vm:TrajetViewModel"
             Title="Trajets Disponibles">

    <Grid>
        <CollectionView ItemsSource="{Binding Trajets}" x:Name="TrajetsCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Trajet">
                    <Frame Margin="10" Padding="15" CornerRadius="10" HasShadow="True">
                        <VerticalStackLayout Spacing="5">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="{Binding TRA_LIEU_DEPART}" FontAttributes="Bold" FontSize="18"/>
                                <Label Text="➔" VerticalOptions="Center"/>
                                <Label Text="{Binding TRA_LIEU_ARRIVEE}" FontAttributes="Bold" FontSize="18"/>
                            </HorizontalStackLayout>

                            <Label Text="{Binding TYP_LIBELLE}" TextColor="Gray" FontSize="14"/>

                            <HorizontalStackLayout Spacing="20" Margin="0,5,0,0">
                                <Label Text="{Binding TRA_DATEDEPART, StringFormat='{0:dd/MM/yyyy HH:mm}'}" />
                                <Label Text="{Binding TRA_PRIX, StringFormat='{0:F2} €'}" 
                                       TextColor="Green" 
                                       FontAttributes="Bold" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ACS_NexTrip.Pages.SettingsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark={StaticResource Gray900}}"
             Title="Utilisateurs">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" 
                BackgroundColor="White"
                Padding="20,10">
            <Border.Shadow>
                <Shadow Brush="{StaticResource Gray900}" Offset="0,2" Radius="8" Opacity="0.1"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto, *, Auto" 
                  ColumnSpacing="20"
                  HeightRequest="60">

                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Border BackgroundColor="{StaticResource Orange500}" HeightRequest="40" WidthRequest="40" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="TM" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="TravelManager" FontSize="22" FontAttributes="Bold" TextColor="Orange" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="30">

                    <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                        <Label Text="Accueil" TextColor="{StaticResource Gray500}" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <BoxView HeightRequest="2" Color="Transparent" HorizontalOptions="Fill"/>
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToDashboardCommand}"/>
                        </VerticalStackLayout.GestureRecognizers>
                    </VerticalStackLayout>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="5" Padding="10,0">
                        <Label Text="Trajets" TextColor="{StaticResource Gray500}" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <BoxView HeightRequest="2" Color="Transparent" HorizontalOptions="Fill"/>
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTrajetsClicked"/>
                        </VerticalStackLayout.GestureRecognizers>
                    </VerticalStackLayout>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                        <Label Text="Utilisateurs" TextColor="Orange" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <BoxView HeightRequest="2" Color="{StaticResource Orange500}" HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="2" Spacing="15" VerticalOptions="Center">
                    <Border BackgroundColor="White" HeightRequest="40" WidthRequest="40" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Label Text="🔔" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <Border BackgroundColor="Orange" HeightRequest="45" WidthRequest="45" StrokeThickness="2" Stroke="{StaticResource Orange300}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22.5"/>
                        </Border.StrokeShape>
                        <Label Text="JD" FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                        <Label Text="Jean Dupont" FontSize="14" FontAttributes="Bold" TextColor="Black"/>
                        <Label Text="Administrateur" FontSize="11" TextColor="Black"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="30" Spacing="20">

                <Label Text="Gestion des Utilisateurs" 
                       FontSize="28" 
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"/>

                <Label Text="Consultez et gérez les membres de l'application" 
                       FontSize="14" 
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                       Margin="0,-15,0,10"/>

                <CollectionView x:Name="UtilisateurCollection">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White" Padding="20">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource Gray900}" Offset="0,4" Radius="10" Opacity="0.08"/>
                                </Border.Shadow>

                                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto" ColumnSpacing="20">

                                    <Border Grid.RowSpan="2" Grid.Column="0" 
                                            BackgroundColor="{StaticResource Orange500}" 
                                            HeightRequest="60" WidthRequest="60" 
                                            StrokeThickness="0" 
                                            VerticalOptions="Start">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="30"/>
                                        </Border.StrokeShape>
                                        <Label Text="👤" FontSize="24" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>

                                    <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="10" VerticalOptions="Center">
                                        <Label Text="{Binding UTI_PRENOM}" FontSize="18" FontAttributes="Bold" TextColor="Black"/>
                                        <Label Text="{Binding UTI_NOM}" FontSize="18" FontAttributes="Bold" TextColor="Black" TextTransform="Uppercase"/>

                                        <Border BackgroundColor="#FFF3E0" Padding="10,2" Margin="10,0,0,0" VerticalOptions="Center">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="8"/>
                                            </Border.StrokeShape>
                                            <Label Text="{Binding ROL_LIBELLE}" TextColor="{StaticResource Orange500}" FontSize="12" FontAttributes="Bold"/>
                                        </Border>
                                    </HorizontalStackLayout>

                                    <Grid Grid.Row="1" Grid.Column="1" 
                                          ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto" 
                                          ColumnSpacing="15" RowSpacing="8" 
                                          Margin="0,15,0,0">

                                        <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="8">
                                            <Label Text="📧" FontSize="14"/>
                                            <Label Text="{Binding UTI_EMAIL}" TextColor="{StaticResource Gray600}" FontSize="13" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="8">
                                            <Label Text="📞" FontSize="14"/>
                                            <Label Text="{Binding UTI_TEL}" TextColor="{StaticResource Gray600}" FontSize="13" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Spacing="8">
                                            <Label Text="🔑" FontSize="14"/>
                                            <Label Text="{Binding UTI_LOGIN}" TextColor="{StaticResource Gray600}" FontSize="13" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="8">
                                            <Label Text="🏠" FontSize="14"/>
                                            <Label Text="{Binding UTI_ADRESSE}" TextColor="{StaticResource Gray600}" FontSize="13" VerticalOptions="Center" LineBreakMode="TailTruncation"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="8">
                                            <Label Text="📍" FontSize="14"/>
                                            <Label Text="{Binding UTI_CP}" TextColor="{StaticResource Gray600}" FontSize="13" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <HorizontalStackLayout Grid.Row="2" Grid.Column="1" Spacing="8">
                                            <Label Text="🎂" FontSize="14"/>
                                            <Label Text="{Binding UTI_DATENAISSANCE}" TextColor="{StaticResource Gray600}" FontSize="13" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Grid>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
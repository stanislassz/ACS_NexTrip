<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ACS_NexTrip.Pages.SettingsPage"
             xmlns:vm="clr-namespace:ACS_NexTrip.ViewModel"
             xmlns:models="clr-namespace:ACS_NexTrip.Models"
             x:DataType="vm:SettingsViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark={StaticResource Gray900}}"
             Title="Utilisateurs">

    <Grid RowDefinitions="Auto, *">

        <Border Grid.Row="0" 
                BackgroundColor="White"
                Padding="20,10">
            <Border.Shadow>
                <Shadow Brush="{StaticResource Gray900}" Offset="0,2" Radius="8" Opacity="0.1"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="Auto, *, Auto" 
                  ColumnSpacing="20"
                  HeightRequest="60">

                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Border BackgroundColor="{StaticResource Orange500}" HeightRequest="40" WidthRequest="40" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Label Text="TM" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="TravelManager" FontSize="22" FontAttributes="Bold" TextColor="Orange" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Spacing="30">

                    <!-- Accueil actif -->
                    <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                        <Label Text="Accueil" 
                           TextColor="Orange" 
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                        <BoxView HeightRequest="2" Color="{StaticResource Orange500}" HorizontalOptions="Fill"/>
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToDashboardCommand}"/>
                        </VerticalStackLayout.GestureRecognizers>
                    </VerticalStackLayout>

                    <!-- Trajets actif -->
                    <VerticalStackLayout VerticalOptions="Center" Spacing="5" Padding="10,0">
                        <Label Text="Trajets" 
                               TextColor="Orange" 
                               FontSize="14"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>

                                            <BoxView HeightRequest="2" 
                                 Color="Orange" 
                                 HorizontalOptions="Fill"/>

                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToTripsCommand}"/>
                        </VerticalStackLayout.GestureRecognizers>
                    </VerticalStackLayout>

                    <!-- Paramètre actif -->
                    <VerticalStackLayout VerticalOptions="Center" Spacing="5">
                        <Label Text="Paramètre" 
                           TextColor="Orange" 
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                        <BoxView HeightRequest="2" Color="Transparent" HorizontalOptions="Fill"/>
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToUsersCommand}"/>
                        </VerticalStackLayout.GestureRecognizers>
                    </VerticalStackLayout>

                </HorizontalStackLayout>

                <HorizontalStackLayout Grid.Column="2" Spacing="15" VerticalOptions="Center">
                    <Border BackgroundColor="White" HeightRequest="40" WidthRequest="40" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20"/>
                        </Border.StrokeShape>
                        <Label Text="🔔" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <Border BackgroundColor="Orange" HeightRequest="45" WidthRequest="45" StrokeThickness="2" Stroke="{StaticResource Orange300}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22.5"/>
                        </Border.StrokeShape>
                        <Label Text="JD" FontSize="16" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>

                    <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                        <Label Text="Jean Dupont" FontSize="14" FontAttributes="Bold" TextColor="Black"/>
                        <Label Text="Administrateur" FontSize="11" TextColor="Black"/>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="30" Spacing="20">

                <Label Text="Paramètres de compte" 
                       FontSize="28" 
                       FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource Gray100}}"/>

                <Label Text="Consultez et modifiez vos informations" 
                       FontSize="14" 
                       TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                       Margin="0,-15,0,10"/>

                <CollectionView ItemsSource="{Binding Utilisateurs}">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Utilisateur">
                            <Border BackgroundColor="White" Padding="20">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="{StaticResource Gray900}" Offset="0,4" Radius="10" Opacity="0.08"/>
                                </Border.Shadow>

                                <Grid Grid.Row="1" Grid.Column="1" 
                                      ColumnDefinitions="*, *" 
                                      RowDefinitions="Auto, Auto, Auto, Auto, Auto" 
                                      ColumnSpacing="15" 
                                      RowSpacing="18" 
                                      Margin="0,20,0,0">

                                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="5">
                                        <Label Text="NOM" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray500}" Margin="5,0"/>
                                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" BackgroundColor="#F8F9FA" Padding="12,0">
                                            <Entry Text="{Binding UTI_NOM}" Placeholder="Ex: Dupont" Keyboard="Text" FontSize="15" HeightRequest="45" TextColor="Black"/>
                                        </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="5">
                                        <Label Text="PRÉNOM" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray500}" Margin="5,0"/>
                                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" BackgroundColor="#F8F9FA" Padding="12,0">
                                            <Entry Text="{Binding UTI_PRENOM}" Placeholder="Ex: Jean" Keyboard="Text" FontSize="15" HeightRequest="45" TextColor="Black"/>
                                        </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="5">
                                        <Label Text="ADRESSE E-MAIL" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray500}" Margin="5,0"/>
                                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" BackgroundColor="#F8F9FA" Padding="12,0">
                                            <Entry Text="{Binding UTI_EMAIL}" Placeholder="jean.dupont@email.com" Keyboard="Email" FontSize="15" HeightRequest="45" TextColor="Black"/>
                                        </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="5">
                                        <Label Text="CODE POSTAL" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray500}" Margin="5,0"/>
                                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" BackgroundColor="#F8F9FA" Padding="12,0">
                                            <Entry Text="{Binding UTI_CP}" Placeholder="75000" Keyboard="Numeric" FontSize="15" HeightRequest="45" TextColor="Black"/>
                                        </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="5">
                                        <Label Text="TÉLÉPHONE" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray500}" Margin="5,0"/>
                                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" BackgroundColor="#F8F9FA" Padding="12,0">
                                            <Entry Text="{Binding UTI_TEL}" Placeholder="06 00 00 00 00" Keyboard="Telephone" FontSize="15" HeightRequest="45" TextColor="Black"/>
                                        </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Spacing="5">
                                        <Label Text="ADRESSE RÉSIDENTIELLE" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray500}" Margin="5,0"/>
                                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" BackgroundColor="#F8F9FA" Padding="12,0">
                                            <Entry Text="{Binding UTI_ADRESSE}" Placeholder="12 rue des Fleurs" Keyboard="Text" FontSize="15" HeightRequest="45" TextColor="Black"/>
                                        </Border>
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Spacing="5">
                                        <Label Text="DATE DE NAISSANCE" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Gray500}" Margin="5,0"/>
                                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" BackgroundColor="#F8F9FA" Padding="12,5">
                                            <DatePicker Date="{Binding UTI_DATENAISSANCE}" Format="dd-MM-yyyy" FontSize="15" TextColor="Black" MinimumHeightRequest="45"/>
                                        </Border>
                                    </VerticalStackLayout>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ACS_NexTrip.ViewModel" 
             x:Class="ACS_NexTrip.Pages.RegisterPage"
             x:DataType="vm:RegisterViewModel">

    <ContentPage.BindingContext>
        <vm:RegisterViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <Grid Padding="20">
            <Frame CornerRadius="10" 
                   BackgroundColor="White" 
                   HasShadow="True" 
                   Padding="25" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" 
                   WidthRequest="350">

                <VerticalStackLayout Spacing="12">

                    <Label Text="Inscription" 
                           FontSize="26" 
                           FontAttributes="Bold" 
                           TextColor="Black" 
                           HorizontalOptions="Center" 
                           Margin="0,0,0,10" />

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Nom" FontSize="11" TextColor="#888888" />
                        <Entry Text="{Binding Nom}" Placeholder="Votre nom" TextColor="Black" />
                        <BoxView HeightRequest="1" Color="#CCCCCC" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Prénom" FontSize="11" TextColor="#888888" />
                        <Entry Text="{Binding Prenom}" Placeholder="Votre prénom" TextColor="Black" />
                        <BoxView HeightRequest="1" Color="#CCCCCC" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Email" FontSize="11" TextColor="#888888" />
                        <Entry Text="{Binding Email}" Placeholder="votre@email.com" Keyboard="Email" TextColor="Black" />
                        <BoxView HeightRequest="1" Color="#CCCCCC" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Identifiant" FontSize="11" TextColor="#888888" />
                        <Entry Text="{Binding Login}" Placeholder="Choisissez un pseudo" TextColor="Black" />
                        <BoxView HeightRequest="1" Color="#CCCCCC" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Mot de passe" FontSize="11" TextColor="#888888" />
                        <Entry Text="{Binding Password}" Placeholder="........" IsPassword="True" TextColor="Black" />
                        <BoxView HeightRequest="1" Color="#CCCCCC" />
                    </VerticalStackLayout>

                    <Button Text="S'INSCRIRE" 
                            Command="{Binding RegisterCommand}" 
                            BackgroundColor="Black" 
                            TextColor="White" 
                            CornerRadius="25" 
                            HeightRequest="50" 
                            Margin="0,15,0,0"
                            FontAttributes="Bold"/>

                    <Button Text="Retour à la connexion" 
                            Command="{Binding GoBackCommand}" 
                            BackgroundColor="Transparent" 
                            TextColor="#555555" 
                            FontSize="12"
                            TextTransform="None" />

                </VerticalStackLayout>
            </Frame>
        </Grid>
    </ScrollView>
</ContentPage>
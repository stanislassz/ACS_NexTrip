<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ACS_NexTrip.Pages.RegisterPage"
             BackgroundColor="#E6F2F5">

    <ScrollView>
        <Grid Padding="20">
            <Frame CornerRadius="10" 
                   BackgroundColor="White" 
                   HasShadow="True" 
                   Padding="25" 
                   HorizontalOptions="Center" 
                   VerticalOptions="Center" 
                   WidthRequest="350">

                <VerticalStackLayout Spacing="12">

                    <Label Text="Inscription" 
                           FontSize="26" 
                           FontAttributes="Bold" 
                           TextColor="Black" 
                           HorizontalOptions="Center" 
                           Margin="0,0,0,10" />

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Nom" FontSize="11" TextColor="#888888" />
                        <Entry x:Name="EntryNom" Placeholder="Votre nom" TextColor="Black" />
                        <BoxView HeightRequest="1" Color="#CCCCCC" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Prénom" FontSize="11" TextColor="#888888" />
                        <Entry x:Name="EntryPrenom" Placeholder="Votre prénom" TextColor="Black" />
                        <BoxView HeightRequest="1" Color="#CCCCCC" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Identifiant" FontSize="11" TextColor="#888888" />
                        <Entry x:Name="EntryLogin" Placeholder="Choissisez un pseudo" TextColor="Black" />
                        <BoxView HeightRequest="1" Color="#CCCCCC" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="2">
                        <Label Text="Mot de passe" FontSize="11" TextColor="#888888" />
                        <Entry x:Name="EntryPassword" Placeholder="*********" IsPassword="True" TextColor="Black" />
                        <BoxView HeightRequest="1" Color="#CCCCCC" />
                    </VerticalStackLayout>

                    <Button Text="S'INSCRIRE" 
                            Clicked="OnInscriptionClicked" 
                            BackgroundColor="Black" 
                            TextColor="White" 
                            CornerRadius="25" 
                            HeightRequest="50" 
                            Margin="0,15,0,0"
                            FontAttributes="Bold"/>

                    <Button Text="Retour à la connexion" 
                            Clicked="OnRetourClicked" 
                            BackgroundColor="Transparent" 
                            TextColor="#555555" 
                            FontSize="12"
                            TextTransform="None" />

                </VerticalStackLayout>
            </Frame>
        </Grid>
    </ScrollView>
</ContentPage>
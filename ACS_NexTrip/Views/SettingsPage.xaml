<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ACS_NexTrip.Views.SettingsPage"
             Shell.NavBarIsVisible="False"
             Title="SettingsPage">
    <CollectionView x:Name="UtilisateurCollection">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <HorizontalStackLayout>
                    <Label Text="{Binding UTI_LOGIN}" TextColor="Black"/>
                    <Label Text="{Binding UTI_NOM}" TextColor="Black"/>
                    <Label Text="{Binding UTI_PRENOM}" TextColor="Black"/>
                    <Label Text="{Binding UTI_DATENAISSANCE}" TextColor="Black"/>
                    <Label Text="{Binding UTI_EMAIL}" TextColor="Black"/>
                </HorizontalStackLayout>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
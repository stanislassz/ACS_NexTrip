<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ACS_NexTrip.Views.TrajetPage"
             BackgroundColor="#121212"
             Title="Destinations disponibles">

    <Grid RowDefinitions="Auto, *" Padding="20" RowSpacing="15">

        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,0,0,10">
            <Label Text="Où partons-nous ?" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="White" />
            <Label Text="Découvrez nos meilleurs itinéraires" 
                   TextColor="#888" 
                   FontSize="14" />
        </VerticalStackLayout>

        <CollectionView x:Name="TrajetsCollection" Grid.Row="1">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="15" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#1E1E1E" 
                           BorderColor="#333" 
                           CornerRadius="15" 
                           HasShadow="True" 
                           Padding="0"
                           HeightRequest="110">

                        <Grid ColumnDefinitions="*, 100">

                            <StackLayout Grid.Column="0" Padding="15" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding TRA_LIEU_DEPART}" 
                                           FontSize="18" 
                                           FontAttributes="Bold" 
                                           TextColor="White" />
                                    <Label Text="➔" 
                                           TextColor="#512BD4" 
                                           VerticalTextAlignment="Center" />
                                    <Label Text="{Binding TRA_LIEU_ARRIVEE}" 
                                           FontSize="18" 
                                           FontAttributes="Bold" 
                                           TextColor="White" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Spacing="8" Margin="0,5,0,0">
                                    <Border BackgroundColor="#2A2A2A" 
                                            Padding="8,2" 
                                            StrokeShape="RoundRectangle 5">
                                        <Label Text="{Binding TYP_LIBELLE}" 
                                               FontSize="11" 
                                               TextColor="#BBB" 
                                               TextTransform="Uppercase"/>
                                    </Border>
                                    <Label Text="{Binding TRA_DATEDEPART, StringFormat='{0:dd MMM yyyy}'}" 
                                           FontSize="12" 
                                           TextColor="#666" 
                                           VerticalTextAlignment="Center"/>
                                </HorizontalStackLayout>
                            </StackLayout>

                            <BoxView Grid.Column="1" Color="#252525" />
                            <StackLayout Grid.Column="1" 
                                         VerticalOptions="Center" 
                                         HorizontalOptions="Center">
                                <Label Text="Dès" 
                                       FontSize="10" 
                                       TextColor="#888" 
                                       HorizontalTextAlignment="Center"/>
                                <Label Text="{Binding TRA_PRIX, StringFormat='{0}€'}" 
                                       FontSize="20" 
                                       FontAttributes="Bold" 
                                       TextColor="#4CAF50" />
                            </StackLayout>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ACS_NexTrip.Views.LoginPage"
             Title="Connexion Erasmus">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

        <Label Text="Bienvenue !" FontSize="24" HorizontalOptions="Center" />

        <Entry x:Name="EntryLogin" Placeholder="Identifiant" />

        <Entry x:Name="EntryPassword" Placeholder="Mot de passe" IsPassword="True" />

        <Button Text="Se connecter" 
                Clicked="OnConnexionClicked" 
                BackgroundColor="Blue" />

        <Button Text="Pas de compte ? Inscrivez-vous ici" 
                Clicked="OnGoToRegisterClicked" 
                BackgroundColor="Transparent"
                TextColor="#2196F3" />

    </VerticalStackLayout>
</ContentPage>